# Flask Environment
FLASK_ENV=production

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_PATH=crawl_history.db

# ============================================================
# Proxy Configuration (for bypassing IP blocks)
# ============================================================
# Enable proxy usage (set to 'true' to activate)
USE_PROXY=false

# Residential Proxy Configuration
# Format: http://username:password@proxy-server:port
#
# Examples:
# - Smartproxy: http://user-yourname:yourpass@gate.smartproxy.com:7000
# - BrightData: http://brd-customer-hl_xxxxx-zone-residential:pass@brd.superproxy.io:22225
# - Oxylabs: http://customer-yourname:yourpass@pr.oxylabs.io:7777
#
# To enable proxy, uncomment and fill in your credentials:
# USE_PROXY=true
# HTTP_PROXY=http://username:password@proxy-server:port
# HTTPS_PROXY=http://username:password@proxy-server:port

# ============================================================
# Crawler Settings (optional overrides)
# ============================================================
# MAX_WORKERS=10
# REQUEST_TIMEOUT=20
# MAX_RETRIES=3
# LOG_LEVEL=INFO
